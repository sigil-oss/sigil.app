{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sigil-wallet",
  "version": "0.1.1-beta.0",
  "identifier": "com.qubic.sigil",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sigil",
        "width": 380,
        "height": 680,
        "minWidth": 360,
        "minHeight": 640,
        "maxWidth": 420,
        "maxHeight": 760,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "sigil"
        ]
      }
    },
    "updater": {
      "pubkey": "REPLACE_WITH_TAURI_UPDATER_PUBLIC_KEY",
      "endpoints": [
        "https://github.com/sigil-app/sigil/releases/latest/download/latest.json"
      ]
    }
  }
}
